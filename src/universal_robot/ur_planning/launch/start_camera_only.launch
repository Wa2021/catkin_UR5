<?xml version="1.0"?>
<launch>
  <!-- 独立的相机启动文件 - 用于深度学习环境 -->
  <!-- 这个launch文件专门用于启动RealSense相机，不包含机械臂控制 -->
  
  <!-- Camera (RealSense) 参数 -->
  <arg name="camera_serial" default=""/>
  <arg name="align_depth" default="true"/>
  <arg name="enable_pointcloud" default="false"/>
  <arg name="enable_sync" default="false"/>
  <arg name="fps" default="30"/>
  <arg name="color_width" default="640"/>
  <arg name="color_height" default="480"/>
  <arg name="depth_width" default="640"/>
  <arg name="depth_height" default="480"/>
  
  <!-- 可选：是否发布TF变换 -->
  <arg name="publish_tf" default="true"/>
  
  <!-- RealSense camera driver -->
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="serial_no" value="$(arg camera_serial)"/>
    <arg name="align_depth" value="$(arg align_depth)"/>
    <arg name="enable_pointcloud" value="$(arg enable_pointcloud)"/>
    <arg name="enable_sync" value="$(arg enable_sync)"/>
    <arg name="fps" value="$(arg fps)"/>
    <arg name="color_width" value="$(arg color_width)"/>
    <arg name="color_height" value="$(arg color_height)"/>
    <arg name="depth_width" value="$(arg depth_width)"/>
    <arg name="depth_height" value="$(arg depth_height)"/>
    <arg name="publish_tf" value="$(arg publish_tf)"/>
  </include>

  <!-- 可选：启动图像查看器 -->
  <arg name="start_image_view" default="false"/>
  <node if="$(arg start_image_view)" pkg="image_view" type="image_view" name="color_image_view" output="screen">
    <remap from="image" to="/camera/color/image_raw"/>
  </node>

</launch>