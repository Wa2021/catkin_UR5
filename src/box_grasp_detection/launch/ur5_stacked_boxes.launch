<?xml version="1.0"?>
<launch>
  <!-- 参数：是否启动堆叠规划器 -->
  <arg name="use_stacked_planner" default="true" />
  
  <!-- 参数：是否启动可视化 -->
  <arg name="visualize" default="true" />
  
  <!-- 相机参数 -->
  <arg name="camera_name" default="camera" />
  <arg name="depth_topic" default="/camera/depth/color/points" />
  
  <!-- 夹爪参数 -->
  <arg name="gripper_width" default="0.050" doc="Robotiq Hand-E: 0.050m, Robotiq 85: 0.085m" />
  
  <!-- ===================================== -->
  <!-- 1. 盒子检测节点 (C++)                 -->
  <!-- ===================================== -->
  <node pkg="box_grasp_detection" type="box_detector_node" name="box_detector" output="screen">
    <!-- 点云输入 -->
    <remap from="~input_cloud" to="$(arg depth_topic)" />
    
    <!-- 预处理参数 -->
    <param name="voxel_leaf_size" value="0.005" />  <!-- 5mm体素 -->
    <param name="z_min" value="0.01" />  <!-- 最小1cm -->
    <param name="z_max" value="1.50" />  <!-- 最大1.5m -->
    
    <!-- 平面去除参数 -->
    <param name="plane_distance_threshold" value="0.01" />
    <param name="plane_max_iterations" value="100" />
    
    <!-- 聚类参数 -->
    <param name="cluster_tolerance" value="0.02" />  <!-- 2cm容差 -->
    <param name="cluster_min_size" value="500" />    <!-- 最小500点 -->
    <param name="cluster_max_size" value="25000" />  <!-- 最大25000点 -->
  </node>
  
  <!-- ===================================== -->
  <!-- 2. 抓取规划节点 (Python)              -->
  <!-- ===================================== -->
  <node pkg="box_grasp_detection" type="box_grasp_planner.py" name="box_grasp_planner" output="screen">
    <param name="gripper_width" value="$(arg gripper_width)" />
    <param name="gripper_depth" value="0.10" />  <!-- 10cm深度 -->
    <param name="approach_distance" value="0.15" />  <!-- 15cm接近距离 -->
    
    <!-- 抓取策略权重 -->
    <param name="weight_stability" value="0.4" />
    <param name="weight_reachability" value="0.3" />
    <param name="weight_collision" value="0.3" />
  </node>
  
  <!-- ===================================== -->
  <!-- 3. 堆叠场景规划器 (可选)              -->
  <!-- ===================================== -->
  <node if="$(arg use_stacked_planner)" 
        pkg="box_grasp_detection" 
        type="stacked_box_planner.py" 
        name="stacked_box_planner" 
        output="screen">
    
    <!-- 堆叠检测参数 -->
    <param name="z_stacking_threshold" value="0.05" />  <!-- 5cm Z轴阈值 -->
    <param name="xy_overlap_threshold" value="0.7" />   <!-- 70% XY重叠 -->
    <param name="min_clearance" value="0.15" />         <!-- 15cm 最小间隙 -->
  </node>
  
  <!-- ===================================== -->
  <!-- 4. 可视化节点 (可选)                  -->
  <!-- ===================================== -->
  <node if="$(arg visualize)" 
        pkg="box_grasp_detection" 
        type="box_grasp_visualizer.py" 
        name="box_grasp_visualizer" 
        output="screen">
    
    <!-- 使用优化后的抓取（如果启用堆叠规划器） -->
    <remap if="$(arg use_stacked_planner)" from="~input_grasps" to="/box_grasps_smart" />
    <remap unless="$(arg use_stacked_planner)" from="~input_grasps" to="/box_grasps" />
    
    <param name="window_name" value="Box Grasp Detection - Stacked Mode" />
    <param name="show_all_grasps" value="false" />  <!-- 只显示最佳抓取 -->
    <param name="coord_frame_size" value="0.05" />  <!-- 坐标系大小 -->
  </node>
  
  <!-- ===================================== -->
  <!-- 说明                                  -->
  <!-- ===================================== -->
  <!-- 
  启动后的话题:
    - /box_grasps (BoxGraspArray) : 原始抓取检测
    - /box_grasps_smart (BoxGraspArray) : 堆叠优化后的抓取 (如果启用)
  
  使用方法:
    1. 启动此launch文件
    2. 运行单帧检测: rosrun box_grasp_detection single_frame_detector.py
    3. 查看结果: 终端输出堆叠分析 + Open3D可视化
  
  参数调整:
    - 不需要堆叠检测: use_stacked_planner:=false
    - 关闭可视化: visualize:=false
    - 更换夹爪: gripper_width:=0.085 (Robotiq 85)
  -->
</launch>
