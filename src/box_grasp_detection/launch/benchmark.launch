<?xml version="1.0"?>
<launch>
  <!-- 基准测试：禁用RViz与实时Open3D，仅用于测时 -->
  <arg name="camera_namespace" default="camera" />

  <!-- 启动相机 -->
  <include file="$(find realsense2_camera)/launch/demo_pointcloud.launch">
    <arg name="camera" value="$(arg camera_namespace)" />
  </include>

  <!-- Box检测器节点 (C++) -->
  <node name="box_detector" pkg="box_grasp_detection" type="box_detector_node" output="screen">
    <param name="input_cloud_topic" value="$(arg camera_namespace)/depth/color/points" />
    <param name="output_frame" value="$(arg camera_namespace)_color_optical_frame" />
    <param name="publish_rate" value="2.0" />
    <!-- 基础参数，与生产一致 -->
    <param name="voxel_leaf_size" value="0.005" />
    <param name="passthrough_min_z" value="0.01" />
    <param name="passthrough_max_z" value="1.5" />
    <param name="cluster_tolerance" value="0.02" />
    <param name="cluster_min_size" value="100" />
    <param name="cluster_max_size" value="25000" />
  </node>

  <!-- 抓取规划器 (Python) -->
  <node name="box_grasp_planner" pkg="box_grasp_detection" type="box_grasp_planner.py" output="screen">
    <param name="gripper_width" value="0.050" />
    <param name="gripper_depth" value="0.05" />
    <param name="approach_distance" value="0.15" />
    <param name="weight_stability" value="0.4" />
    <param name="weight_reachability" value="0.3" />
    <param name="weight_collision" value="0.3" />
  </node>

  <!-- Benchmark一次性Open3D测时脚本 -->
  <node name="benchmark_once" pkg="box_grasp_detection" type="benchmark_performance.py" output="screen" />

  <!-- 不启动RViz与Open3D实时可视化，减少干扰 -->
</launch>
