<?xml version="1.0"?>
<launch>
  <!-- Box Grasp Detection for UR5 with RealSense D435 -->
  <!-- 眼在手抓取系统 - 集成版 -->
  
  <!-- 参数配置 -->
  <arg name="camera_namespace" default="camera" />
  <arg name="use_snapshot_control" default="true" />
  <arg name="auto_freeze_enabled" default="false" />
  <arg name="freeze_delay" default="8.0" />
  <arg name="use_rviz" default="true" />
  
  <!-- 1. 启动RealSense相机 -->
  <include file="$(find realsense2_camera)/launch/demo_pointcloud.launch">
    <arg name="camera" value="$(arg camera_namespace)" />
  </include>
  
  <!-- 2. 快照控制器（可选） -->
  <group if="$(arg use_snapshot_control)">
    <node pkg="ur5_gripper_moveit_config" type="snapshot_control.py" 
          name="snapshot_controller" output="screen">
      <param name="auto_freeze_enabled" value="$(arg auto_freeze_enabled)" />
      <param name="freeze_delay" value="$(arg freeze_delay)" />
    </node>
    
    <!-- 使用中继的点云话题 -->
    <param name="box_detector/input_cloud_topic" value="/camera/depth/color/points_relay" />
  </group>
  
  <!-- 如果不使用快照控制，直接使用相机点云 -->
  <group unless="$(arg use_snapshot_control)">
    <param name="box_detector/input_cloud_topic" value="/camera/depth/color/points" />
  </group>
  
  <!-- 3. Box检测器节点 (C++) -->
  <node name="box_detector" pkg="box_grasp_detection" type="box_detector_node" output="screen">
    <!-- 检测参数 -->
    <param name="voxel_leaf_size" value="0.005" />
    <param name="passthrough_min_z" value="0.01" />
    <param name="passthrough_max_z" value="1.5" />
    <param name="cluster_tolerance" value="0.02" />
    <param name="cluster_min_size" value="100" />
    <param name="cluster_max_size" value="25000" />
    <param name="plane_distance_threshold" value="0.01" />
  </node>

  <!-- 4. RViz可视化（默认启动，添加稳定性参数） -->
  <node if="$(arg use_rviz)" name="rviz" pkg="rviz" type="rviz" output="screen" 
        respawn="true" respawn_delay="2"
        args="-d $(find box_grasp_detection)/config/box_detection.rviz">
    <!-- respawn: 自动重启崩溃的RViz -->
    <!-- respawn_delay: 重启延迟2秒 -->
    <env name="LIBGL_ALWAYS_SOFTWARE" value="1" />  <!-- 使用软件渲染（虚拟机友好） -->
  </node>
  
</launch>
